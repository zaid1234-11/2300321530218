{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "../logging_middleware/*": ["../logging_middleware/*"]
    }
  },
  "include": ["./**/*.ts", "../logging_middleware/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
